# Replicate API token — create one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Vercel Blob — auto-added to your Vercel project when you create a Blob
# store (Storage tab in the Vercel dashboard). For local dev, run:
#   vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# Stripe ─────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_or_live_xxx

# Webhook signing secret — created when you add an endpoint at
# https://dashboard.stripe.com/webhooks pointing at /api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring price IDs — create two products in your Stripe dashboard:
#   • "FaceForge Monthly" — $10 / month  → price_xxx
#   • "FaceForge Yearly"  — $60 / year   → price_xxx
STRIPE_PRICE_MONTHLY=price_monthly_xxx
STRIPE_PRICE_YEARLY=price_yearly_xxx

# Public URL of this app, used as the Stripe Checkout return URL.
APP_URL=https://your-app.vercel.app
