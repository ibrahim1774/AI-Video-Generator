# Replicate API token \u2014 https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Vercel Blob \u2014 auto-added by Vercel when you create a Blob store.
# For local dev: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# Stripe \u2014 only the secret key is required. Products + prices are
# created automatically the first time a user hits checkout.
STRIPE_SECRET_KEY=sk_test_or_live_xxx

# Optional: explicit return URL for Stripe Checkout. If unset, derived
# from the request's Origin/Host headers.
APP_URL=

# Meta Conversions API access token. Pixel ID is hardcoded in
# components/MetaPixel.js + lib/meta.js.
META_ACCESS_TOKEN=

# Supabase \u2014 for auth + profiles table.
# Get these from Supabase dashboard \u2192 Project Settings \u2192 API.
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
