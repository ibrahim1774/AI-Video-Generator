# Replicate API token — create one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Vercel Blob — auto-added to your Vercel project when you create a Blob
# store (Storage tab in the Vercel dashboard). For local dev, run:
#   vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# Stripe — only the secret key is required. Products + prices are
# created automatically the first time someone hits checkout.
STRIPE_SECRET_KEY=sk_test_or_live_xxx

# Optional: explicit return URL for Stripe Checkout. If unset, we
# derive it from the request's Origin/Host headers.
APP_URL=

# Stripe webhook signing secret. Add an endpoint at
# https://<your-deploy>/api/stripe-webhook in the Stripe dashboard
# subscribed to `invoice.payment_succeeded`, then paste the secret here.
# Used to fire the Meta CAPI Purchase event when a real charge clears
# (after the 1-day trial converts).
STRIPE_WEBHOOK_SECRET=

# Meta (Facebook) Pixel + Conversions API
# Pixel ID is exposed to the browser \u2014 safe to commit. Access token
# is server-only \u2014 keep it secret.
NEXT_PUBLIC_META_PIXEL_ID=26490568997297314
META_ACCESS_TOKEN=
